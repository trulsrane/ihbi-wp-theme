{
    "$schema": "https://schemas.wp.org/wp/6.9/theme.json",
    "version": 3,
    "settings": {
        "color": {
            "palette": [
                {
                    "color": "#FFFFFF",
                    "name": "Base",
                    "slug": "base"
                },
                {
                    "color": "#333333",
                    "name": "Contrast",
                    "slug": "contrast"
                },
                {
                    "color": "#ffa92c",
                    "name": "Gold",
                    "slug": "accent-1"
                },
                {
                    "color": "#ffc168",
                    "name": "Gold accent",
                    "slug": "accent-2"
                },
                {
                    "color": "#3352BA",
                    "name": "Blue",
                    "slug": "accent-3"
                },
                {
                    "color": "#7B92E2",
                    "name": "Blue accent",
                    "slug": "accent-4"
                },
                {
                    "color": "#f6faf9",
                    "name": "Off-white",
                    "slug": "accent-5"
                },
                {
                    "color": "#333333",
                    "name": "Dark gray",
                    "slug": "accent-6"
                }
            ]
        },
        "layout": {
            "contentSize": "45rem",
            "wideSize": "75rem"
        },
        "shadow": {
            "presets": [
                {
                    "name": "Card shadow",
                    "shadow": "0px 4px 8px 0px rgba(0, 0, 0, 0.2)",
                    "slug": "shadow-1"
                }
            ]
        },
        "typography": {
            "fontFamilies": [
                {
                    "fontFamily": "\"Roboto\", sans-serif",
                    "slug": "roboto",
                    "name": "Roboto",
                    "fontFace": [
                        {
                            "fontFamily": "Roboto",
                            "fontWeight": "100 900",
                            "fontStyle": "normal",
                            "src": [ "file:./assets/fonts/Roboto/Roboto-VariableFont.ttf" ]
                        },
                        {
                            "fontFamily": "Roboto",
                            "fontWeight": "100 900",
                            "fontStyle": "italic",
                            "src": [ "file:./assets/fonts/Roboto/Roboto-Italic-VariableFont.ttf" ]
                        }
                    ]
                },
                {
                    "fontFamily": "\"Open Sans\", sans-serif",
                    "slug": "open-sans",
                    "name": "Open Sans",
                    "fontFace": [
                        {
                            "fontFamily": "Open Sans",
                            "fontWeight": "300 800",
                            "fontStyle": "normal",
                            "src": [ "file:./assets/fonts/Open_Sans/OpenSans-VariableFont.ttf" ]
                        },
                        {
                            "fontFamily": "Open Sans",
                            "fontWeight": "300 800",
                            "fontStyle": "italic",
                            "src": [ "file:./assets/fonts/Open_Sans/OpenSans-Italic-VariableFont.ttf" ]
                        }
                    ]
                }
            ]
        }
    },
    "styles": {
        "color": {
            "text": "var(--wp--preset--color--accent-6)"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--open-sans)",
            "fontSize": "var(--wp--preset--font-size--large)",
            "fontStyle": "normal",
            "fontWeight": "300",
            "letterSpacing": "0.5px",
            "lineHeight": "1.6"
        },
        "blocks": {
            "core/post-template": {
                "spacing": {
                    "blockGap": "2em"
                }
            },
            "core/accordion": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--open-sans)"
                }
            },
            "core/button": {
                "border": {
                    "radius": {
                        "bottomLeft": "8px",
                        "bottomRight": "8px",
                        "topLeft": "8px",
                        "topRight": "8px"
                    }
                },
                "shadow": "none",
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--open-sans)"
                },
                "variations": {
                    "outline": {
                        "border": {
                            "color": "var(--wp--preset--color--accent-3)",
                            "width": "1px"
                        },
                        "color": {
                            "text": "var(--wp--preset--color--accent-3)"
                        },
                        "css": ".wp-block-button__link:not(.has-background):hover {background-color:color-mix(in srgb, var(--wp--preset--color--contrast) 5%, transparent);}",
                        "spacing": {
                            "padding": {
                                "bottom": "calc(1rem - 1px)",
                                "left": "calc(2.25rem - 1px)",
                                "right": "calc(2.25rem - 1px)",
                                "top": "calc(1rem - 1px)"
                            }
                        }
                    }
                }
            },
            "core/code": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--roboto)"
                }
            },
            "core/column": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--open-sans)"
                }
            },
            "core/heading": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--roboto)"
                }
            },
            "core/image": {
                "border": { "radius": "8px" },
                "shadow": "none"
            },
            "core/post-featured-image": {
                "border": { "radius": "8px" }
            },
            "core/video": {
                "border": { "radius": "8px" }
            },
            "core/cover": {
                "border": { "radius": "8px" }
            },
            "core/embed": {
                "border": { "radius": "8px" }
            },
            "core/list": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--open-sans)"
                }
            },
            "core/list-item": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--open-sans)"
                }
            },
            "core/paragraph": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--open-sans)"
                },
                "variations": {
                    "text-display": {
                        "typography": {
                            "fontFamily": "var(--wp--preset--font-family--open-sans)"
                        }
                    }
                }
            },
            "core/site-title": {
                "typography": {
                    "letterSpacing": "0px"
                }
            }
        },
        "elements": {
            "button": {
                "color": {
                    "background": "var(--wp--preset--color--accent-3)",
                    "text": "var(--wp--preset--color--base)"
                },
                ":hover": {
                    "color": {
                        "background": "color-mix(in srgb, var(--wp--preset--color--contrast) 85%, transparent)",
                        "text": "var(--wp--preset--color--base)"
                    }
                },
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--roboto)",
                    "fontWeight": "300"
                }
            },
            "caption": {
                "color": {
                    "text": "var(--wp--preset--color--accent-6)"
                },
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--open-sans)"
                }
            },
            "heading": {
                "color": {
                    "text": "var(--wp--preset--color--accent-6)"
                },
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--roboto)",
                    "fontStyle": "normal",
                    "fontWeight": "300"
                }
            },
            "link": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--open-sans)"
                }
            }
        }
    }
}